cc_binary {
    name: "android.hardware.boot-service.qti",
    defaults: ["android.hardware.boot-service.qti_defaults"],
    static_libs: ["librecovery_updater.moto_kona"],
}

cc_binary {
    name: "android.hardware.boot-service.qti.recovery",
